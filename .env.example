# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only used server-side (API routes, middleware)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Ads API (used by droplet auditor, not by Next.js)
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=

# Google Sheets API (pSEO Content tracker — server-side only)
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Email Signatures — dedicated service account for Admin SDK + Gmail API (DWD)
GOOGLE_ES_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_ADMIN_EMAIL=admin@synup.com
